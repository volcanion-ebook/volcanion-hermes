# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
vendor/

# Go workspace file
go.work

# Build directories
bin/
dist/
build/

# Environment files
.env.local
.env.development
.env.test
.env.production

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/

# Coverage files
coverage.out
coverage.html

# Temporary files
tmp/
temp/

# Docker volumes
docker-data/

# Upload directories (if storing locally)
uploads/

# Configuration backups
*.bak

# Node modules (if using any JS tools)
node_modules/

# Package files
*.tar.gz
*.zip

# Database files
*.db
*.sqlite
*.sqlite3
